meta {
  name: Get Feature Metrics
  type: http
  seq: 3
}

get {
  url: {{baseUrl}}/ontology/v1/features/1/metrics
  body: none
  auth: none
}

params:query {
  ~window_start_from: 2024-01-01T00:00:00Z
  ~window_start_to: 2026-12-31T23:59:59Z
  ~window_minutes: 60
}

headers {
  X-Scope: features:view
}

vars:pre-request {
  baseUrl: http://localhost:4441
}
