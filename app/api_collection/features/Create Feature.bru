meta {
  name: Create Feature
  type: http
  seq: 4
}

post {
  url: {{baseUrl}}/ontology/v1/features
  body: json
  auth: none
}

headers {
  X-Scope: features:manage
}

vars:pre-request {
  baseUrl: http://localhost:4441
}

body:json {
  {
    "code": "CUST_ONBOARD",
    "name": "Customer Onboarding",
    "description": "Flow for new user registration",
    "is_active": true
  }
}
