meta {
  name: Update Feature
  type: http
  seq: 5
}

patch {
  url: {{baseUrl}}/ontology/v1/features/1
  body: json
  auth: none
}

headers {
  X-Scope: features:manage
}

vars:pre-request {
  baseUrl: http://localhost:4441
}

body:json {
  {
    "name": "Customer Onboarding",
    "description": "End-to-end onboarding for new users",
    "is_active": true
  }
}
