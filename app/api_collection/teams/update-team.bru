meta {
  name: Update Team
  type: http
  seq: 4
}

patch {
  url: {{ontology_host}}/ontology/v1/teams/{{team_id}}
  body: json
  auth: none
}

headers {
  X-Scope: teams:manage
}

body:json {
  {
    "name": "Platform Team",
    "slack_channel": "#platform",
    "oncall_email": "platform@company.com"
  }
}

vars:pre-request {
  ~team_id: 1
}

docs {
  # Update Team
  
  Updates a team by ID.
}
