meta {
  name: Get All Services
  type: http
  seq: 1
}

get {
  url: {{baseUrl}}/ontology/v1/services?code=auth-service
  body: none
  auth: none
}

params:query {
  code: auth-service
  ~name: Auth
  ~criticality_level: LOW
  ~repository_url: ohoi
  ~created_at_from: 2024-01-01T00:00:00Z
  ~created_at_to: 2026-12-31T23:59:59Z
  ~page: 1
  ~limit: 10
}

headers {
  X-Scope: services:view
}

vars:pre-request {
  baseUrl: http://localhost:4441
}
